{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user (client or barber).",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["client", "barber"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Barbershop service.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "durationMinutes": { "type": "number" }
      },
      "required": ["id", "name", "price", "durationMinutes"]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "Scheduled booking.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "barberId": { "type": "string" },
        "serviceId": { "type": "string" },
        "serviceName": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "dataHora": { "type": "object", "description": "Firestore Timestamp" },
        "status": { "type": "string", "enum": ["pendente", "confirmado", "cancelado"] },
        "createdAt": { "type": "object", "description": "Firestore Timestamp" }
      },
      "required": ["clientId", "barberId", "serviceId", "dataHora", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "#/backend/entities/User",
      "description": "User profiles."
    },
    "/services/{serviceId}": {
      "schema": "#/backend/entities/Service",
      "description": "Available services."
    },
    "/appointments/{appointmentId}": {
      "schema": "#/backend/entities/Appointment",
      "description": "Booking records."
    }
  }
}