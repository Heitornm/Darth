
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterBarber() {
      return isSignedIn() && request.auth.token.email == 'darthbarber@darth.com.br';
    }

    // Regras simplificadas e robustas para evitar erros de permissão
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Permite leitura e listagem para qualquer usuário logado.
      // Isso resolve o erro de permissão no dashboard e na verificação de horários.
      allow read, list: if isSignedIn();
      
      // Apenas o cliente logado pode criar seu agendamento
      allow create: if isSignedIn() 
        && request.resource.data.clientId == request.auth.uid;

      // Apenas o cliente ou o barbeiro mestre podem editar/excluir
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.clientId || 
        isMasterBarber()
      );
    }
    
    // Bloqueio padrão para segurança
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
