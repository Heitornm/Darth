rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements RBAC for the barbershop.
     * Permissions are granted based on user identity (auth.uid) or email (for the Master Barber).
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Verifies if a user is the Master Barber by email. */
    function isMasterBarber() {
      return isSignedIn() && request.auth.token.email == 'darthbarber@darth.com.br';
    }

    function canAccessAppointment(data) {
      return isSignedIn() && (
        request.auth.uid == data.clientId || 
        request.auth.uid == data.barberId ||
        isMasterBarber()
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /roles_barber/{barberId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /appointments/{appointmentId} {
      /** 
       * allow list: needed for checking availability and for the barber dashboard.
       */
      allow list: if isSignedIn();
      
      allow get: if canAccessAppointment(resource.data);
      
      allow create: if isSignedIn() 
        && request.resource.data.clientId == request.auth.uid;

      allow update, delete: if canAccessAppointment(resource.data);
    }
  }
}