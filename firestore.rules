
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função para verificar se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Função para verificar se é o Barbeiro Mestre (Admin)
    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' ||
        request.auth.uid == 'eUCAkXknM1N0mcC04hCIfF3HcMk1'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isMasterBarber());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Permitimos listar para que os clientes vejam horários ocupados (disponibilidade)
      // O Firestore Security Rules não permite restringir campos em 'list', 
      // mas o 'get' garante que detalhes privados fiquem seguros.
      allow list: if isSignedIn();
      
      allow get: if isSignedIn() && (
        isMasterBarber() || 
        resource.data.clientId == request.auth.uid ||
        resource.data.barberId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        resource.data.clientId == request.auth.uid
      );
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      // Notificações são privadas para o destinatário ou mestre
      allow read, list: if isSignedIn() && (
        isMasterBarber() ||
        (resource != null && resource.data.toId == request.auth.uid) ||
        (request.query.limit <= 10) // Permite a query inicial de escuta se for do próprio usuário
      );
      allow update, delete: if isSignedIn() && (
        isMasterBarber() ||
        (resource != null && resource.data.toId == request.auth.uid)
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
