rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements RBAC for the barbershop.
     * Permissions are granted based on user identity (auth.uid) or email (for the Master Barber).
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Verifies if a user is the Master Barber by email. */
    function isMasterBarber() {
      return isSignedIn() && request.auth.token.email == 'darthbarber@darth.com.br';
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /roles_barber/{barberId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    match /appointments/{appointmentId} {
      /** 
       * allow read: Permite listagem para verificação de disponibilidade 
       * e acesso individual para as partes envolvidas.
       */
      allow read: if isSignedIn();
      
      /**
       * allow create: Permite que qualquer usuário logado crie um agendamento
       * desde que o clientId corresponda ao seu próprio UID.
       */
      allow create: if isSignedIn() 
        && request.resource.data.clientId == request.auth.uid;

      /**
       * allow update, delete: Apenas o dono do agendamento ou o barbeiro mestre.
       */
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.clientId || 
        request.auth.uid == resource.data.barberId ||
        isMasterBarber()
      );
    }
    
    // Fallback security rule - trigger redeploy
    match /{path=**} {
      allow read, write: if false;
    }
  }
}