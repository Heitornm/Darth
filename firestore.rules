rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterBarber() {
      return isSignedIn() && request.auth.token.email == 'darthbarber@darth.com.br';
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Permite leitura e listagem para qualquer usuário logado. 
      // Isso é necessário para verificar disponibilidade e para o barbeiro ver sua agenda.
      allow read, list: if isSignedIn();
      
      // Apenas o cliente logado pode criar seu próprio agendamento
      allow create: if isSignedIn() 
        && request.resource.data.clientId == request.auth.uid;

      // Apenas o cliente dono ou o barbeiro mestre podem editar/excluir
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.clientId || 
        isMasterBarber()
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}