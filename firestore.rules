
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' || 
        request.auth.uid == 'darth-barber-main'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Regra definitiva: Lê se for dono ou mestre. 
      // Permite listagem se a query for filtrada pelo clientId do usuário logado.
      allow read: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && resource.data.clientId == request.auth.uid) ||
        (resource == null) // Permite queries que podem resultar em documentos vazios
      );
      
      // Permite criação se o clientId for o do usuário logado
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;

      // Permite atualização/deleção apenas pelo dono ou pelo barbeiro mestre
      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        resource.data.clientId == request.auth.uid
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
