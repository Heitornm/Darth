
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' || 
        request.auth.uid == 'darth-barber-main'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Permite leitura se for o barbeiro mestre ou se o documento pertencer ao usuário logado.
      // O Firestore exige que a query do cliente contenha um filtro que bata com essa regra.
      allow read: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && resource.data.clientId == request.auth.uid) ||
        (resource != null && resource.data.barberId == request.auth.uid)
      );
      
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;

      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && resource.data.clientId == request.auth.uid)
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
