rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * Sistema de permissões baseado em RBAC para a barbearia.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterBarber() {
      return isSignedIn() && request.auth.token.email == 'darthbarber@darth.com.br';
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /services/{serviceId} {
      allow read: if isSignedIn();
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      /** 
       * allow list: Essencial para verificar disponibilidade e para o dashboard do barbeiro.
       * allow get: Acesso individual.
       */
      allow list, get: if isSignedIn();
      
      /**
       * allow create: Clientes criam seus próprios agendamentos.
       */
      allow create: if isSignedIn() 
        && request.resource.data.clientId == request.auth.uid;

      /**
       * allow update, delete: Apenas o dono ou o barbeiro mestre.
       */
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.clientId || 
        isMasterBarber()
      );
    }
    
    // Fallback
    match /{path=**} {
      allow read, write: if false;
    }
  }
}