rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' || 
        request.auth.uid == 'darth-barber-main'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Permite leitura e listagem para qualquer usuário logado.
      // Isso é necessário para que clientes vejam horários ocupados (disponibilidade).
      allow read, list: if isSignedIn();
      
      // Permite criação se o clientId for o do usuário logado
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;

      // Permite atualização/deleção apenas pelo dono ou pelo barbeiro mestre
      allow update, delete: if isSignedIn() && (
        resource.data.clientId == request.auth.uid || 
        isMasterBarber()
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}