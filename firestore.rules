
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isBarber() {
      return isSignedIn() && (getUserData().role == 'barber' || request.auth.token.email == 'darthbarber@darth.com.br');
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' || 
        request.auth.uid == 'darth-barber-main'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isMasterBarber());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      allow get: if isSignedIn() && (
        isMasterBarber() || 
        resource.data.clientId == request.auth.uid ||
        resource.data.barberId == request.auth.uid
      );
      
      allow list: if isSignedIn() && (
        isMasterBarber() || 
        (resource == null || resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid)
      );

      allow create: if isSignedIn() && (
        isMasterBarber() || 
        request.resource.data.clientId == request.auth.uid
      );

      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && (resource.data.clientId == request.auth.uid || resource.data.barberId == request.auth.uid))
      );
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn() && resource.data.toId == request.auth.uid;
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
