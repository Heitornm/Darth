
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' ||
        request.auth.uid == 'eUCAkXknM1N0mcC04hCIfF3HcMk1'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isMasterBarber());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Liberamos leitura para usuários logados para que o calendário de disponibilidade funcione
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        resource.data.clientId == request.auth.uid
      );
    }

    match /notifications/{notificationId} {
      // Liberamos leitura para o sistema de notificações em tempo real
      allow read, list: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        isMasterBarber() ||
        resource.data.toId == request.auth.uid
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
