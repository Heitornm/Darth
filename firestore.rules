rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' || 
        request.auth.uid == 'darth-barber-main'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isMasterBarber());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Permite leitura individual se for o mestre ou o dono
      allow get: if isSignedIn() && (
        isMasterBarber() || 
        resource.data.clientId == request.auth.uid || 
        resource.data.clientEmail == request.auth.token.email
      );

      // Permite listagem (query) se for o mestre ou se houver filtro pelo clientId do usuário
      allow list: if isSignedIn() && (
        isMasterBarber() || 
        request.query.filters.clientId == request.auth.uid
      );
      
      // Criação: Usuário logado vinculando seu próprio ID
      allow create: if isSignedIn() && (
        isMasterBarber() || 
        (request.resource.data.clientId == request.auth.uid)
      );

      // Edição/Exclusão: Mestre ou dono
      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && resource.data.clientId == request.auth.uid)
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}