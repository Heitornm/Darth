
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Comentário para forçar redeploy e garantir permissões consistentes
    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' ||
        request.auth.uid == 'eUCAkXknM1N0mcC04hCIfF3HcMk1'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isMasterBarber());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // O Barbeiro Mestre pode listar tudo. Clientes só listam se filtrarem pelo seu próprio clientId.
      allow list: if isSignedIn() && (
        isMasterBarber() || 
        request.query.filters.clientId == request.auth.uid
      );
      
      // Leitura individual permitida para os envolvidos ou admin
      allow get: if isSignedIn() && (
        isMasterBarber() || 
        resource.data.clientId == request.auth.uid ||
        resource.data.barberId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        resource.data.clientId == request.auth.uid
      );
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      allow read, list: if isSignedIn() && (
        isMasterBarber() ||
        (resource != null && resource.data.toId == request.auth.uid) ||
        (request.query.limit <= 10 && request.query.filters.toId == request.auth.uid)
      );
      allow update, delete: if isSignedIn() && (
        isMasterBarber() ||
        resource.data.toId == request.auth.uid
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
