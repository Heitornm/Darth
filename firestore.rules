rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' || 
        request.auth.uid == 'darth-barber-main'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isMasterBarber());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Regra de leitura para documentos individuais
      allow get: if isSignedIn() && (
        isMasterBarber() || 
        resource.data.clientId == request.auth.uid
      );
      
      // Regra de listagem (queries): O filtro deve bater com a regra
      allow list: if isSignedIn() && (
        isMasterBarber() || 
        request.query.limit <= 100 && (resource == null || resource.data.clientId == request.auth.uid)
      );

      // Criação: Cliente cria para si, Mestre cria qualquer um
      allow create: if isSignedIn() && (
        isMasterBarber() || 
        request.resource.data.clientId == request.auth.uid
      );

      // Edição/Exclusão
      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && resource.data.clientId == request.auth.uid)
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}