
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' || 
        request.auth.uid == 'darth-barber-main'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Regra de leitura: Mestre vê tudo, Cliente vê apenas o dele.
      // Importante: O cliente DEVE usar o filtro where("clientId", "==", auth.uid) na query.
      allow read: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && resource.data.clientId == request.auth.uid) ||
        (request.query.limit <= 100 && request.resource == null && request.auth.uid != null)
      );
      
      // Apenas o cliente logado pode criar seu agendamento
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;

      // Apenas o barbeiro mestre ou o próprio cliente podem editar/cancelar
      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && resource.data.clientId == request.auth.uid)
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
