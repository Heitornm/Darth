rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset implements RBAC and DBAC for a barbershop.
     * Permissions are granted based on user identity (auth.uid) and roles (email or roles_barber collection).
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Verifies if a user is the Master Barber by email or DBAC. */
    function isBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' ||
        exists(/databases/$(database)/documents/roles_barber/$(request.auth.uid))
      );
    }

    function isAppointmentParticipant(data) {
      return isSignedIn() && (
        request.auth.uid == data.clientId || 
        request.auth.uid == data.barberId ||
        isBarber()
      );
    }

    // --- Collection Rules ---

    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    match /roles_barber/{barberId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; 
    }

    match /services/{serviceId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false;
    }

    match /appointments/{appointmentId} {
      /** 
       * allow list: if isSignedIn()
       * Needed for clients to check availability (overlapping slots) 
       * and for the barber to see their agenda.
       */
      allow list: if isSignedIn();
      
      allow get: if isAppointmentParticipant(resource.data);
      
      allow create: if isSignedIn() 
        && request.resource.data.clientId == request.auth.uid;

      allow update, delete: if isAppointmentParticipant(resource.data);
    }
  }
}