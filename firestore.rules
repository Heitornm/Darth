
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Função para verificar se o usuário está logado
    function isSignedIn() {
      return request.auth != null;
    }

    // Função para verificar se é o Barbeiro Mestre (Admin)
    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' ||
        request.auth.uid == 'eUCAkXknM1N0mcC04hCIfF3HcMk1'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isMasterBarber());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Permitimos listagem para qualquer usuário logado para que clientes vejam horários ocupados (disponibilidade)
      allow list: if isSignedIn();
      
      // Detalhes privados do agendamento só para os envolvidos
      allow get: if isSignedIn() && (
        isMasterBarber() || 
        resource.data.clientId == request.auth.uid ||
        resource.data.barberId == request.auth.uid
      );
      
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        resource.data.clientId == request.auth.uid
      );
    }

    match /notifications/{notificationId} {
      allow create: if isSignedIn();
      // Permitimos a listagem para evitar erros em queries filtradas
      allow list: if isSignedIn();
      
      // Conteúdo da notificação é privado
      allow get: if isSignedIn() && (
        isMasterBarber() ||
        resource.data.toId == request.auth.uid
      );
      
      allow update, delete: if isSignedIn() && (
        isMasterBarber() ||
        resource.data.toId == request.auth.uid
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
