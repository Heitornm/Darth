
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' || 
        request.auth.uid == 'darth-barber-main'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Permite leitura se for o barbeiro mestre ou se o agendamento pertencer ao e-mail do usuário
      allow read: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && resource.data.clientEmail == request.auth.token.email) ||
        (resource == null)
      );
      
      // Apenas usuários logados podem criar agendamentos vinculando seu e-mail
      allow create: if isSignedIn() && request.resource.data.clientEmail == request.auth.token.email;

      // Apenas o barbeiro mestre ou o próprio dono podem editar/cancelar
      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && resource.data.clientEmail == request.auth.token.email)
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
