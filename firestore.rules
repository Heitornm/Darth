rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' || 
        request.auth.uid == 'darth-barber-main'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Permite listagem para qualquer usuário logado (necessário para verificação de disponibilidade e gestão)
      allow list: if isSignedIn();
      
      // Permite leitura individual se for o dono do agendamento ou o barbeiro mestre
      allow get: if isSignedIn() && (
        request.auth.uid == resource.data.clientId || 
        isMasterBarber()
      );
      
      // Permite criação se o cliente for o próprio usuário logado
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;

      // Permite atualização e deleção pelo dono ou pelo barbeiro mestre
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.clientId || 
        isMasterBarber()
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}