rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterBarber() {
      return isSignedIn() && request.auth.token.email == 'darthbarber@darth.com.br';
    }

    // Perfil de usuário
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Serviços disponíveis
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    // Agendamentos
    match /appointments/{appointmentId} {
      // Permite leitura (get e list) para qualquer usuário autenticado.
      // Isso é necessário para que clientes vejam horários ocupados e o barbeiro veja sua agenda.
      allow read: if isSignedIn();
      
      // Permite criar agendamento se o clientId corresponder ao usuário logado
      allow create: if isSignedIn() && request.resource.data.clientId == request.auth.uid;

      // Permite atualizar ou excluir se for o dono do agendamento ou o barbeiro mestre
      allow update, delete: if isSignedIn() && (
        request.auth.uid == resource.data.clientId || 
        isMasterBarber()
      );
    }
    
    // Bloqueio padrão para outros caminhos
    match /{path=**} {
      allow read, write: if false;
    }
  }
}