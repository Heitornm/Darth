
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isMasterBarber() {
      return isSignedIn() && (
        request.auth.token.email == 'darthbarber@darth.com.br' || 
        request.auth.uid == 'darth-barber-main'
      );
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && (request.auth.uid == userId || isMasterBarber());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isMasterBarber();
    }

    match /appointments/{appointmentId} {
      // Leitura/Lista: Mestre ou dono do registro (pelo UID ou Email)
      allow read, list: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && (resource.data.clientId == request.auth.uid || resource.data.clientEmail == request.auth.token.email)) ||
        (resource == null) // Permite a query inicial que será filtrada
      );
      
      // Criação: Mestre ou usuário logado vinculando seu próprio ID/Email
      allow create: if isSignedIn() && (
        isMasterBarber() || 
        (request.resource.data.clientId == request.auth.uid && request.resource.data.clientEmail == request.auth.token.email)
      );

      // Edição/Exclusão: Mestre ou dono
      allow update, delete: if isSignedIn() && (
        isMasterBarber() || 
        (resource != null && (resource.data.clientId == request.auth.uid || resource.data.clientEmail == request.auth.token.email))
      );
    }
    
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
